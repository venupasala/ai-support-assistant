# ── Embedding model ──
HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── LLM backend: "openai" or "local" ──
# "local" uses extractive summarisation (no API key needed)
LLM_BACKEND=local

# ── OpenAI (only needed if LLM_BACKEND=openai) ──
OPENAI_API_KEY=

# ── FAISS persistent storage path ──
VECTOR_STORE_DIR=./vector_db

# ── Text splitter settings ──
CHUNK_SIZE=500
CHUNK_OVERLAP=50
